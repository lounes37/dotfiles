# PowerShell script for chezmoi to set up Scoop, Git, and install packages from .chezmoidata/scoop-packages.json
# Only runs on Windows using chezmoi's os check
# Uses package.bucket and package.name from JSON

{{ if eq .chezmoi.os "windows" }}
$ErrorActionPreference = "Stop"
Set-StrictMode -Version Latest

# Function to check if a command exists
function Test-CommandExists {
    param ([string]$Command)
    return $null -ne (Get-Command $Command -ErrorAction SilentlyContinue)
}

# Function to get installed Scoop buckets
function Get-ScoopBuckets {
    $buckets = & scoop bucket list 2>$null
    if ($buckets) {
        if ($buckets | Get-Member -Name Name -ErrorAction SilentlyContinue) {
            return $buckets.Name
        }
        return $buckets -split "`n" | Where-Object { $_ } | ForEach-Object { $_.Trim() }
    }
    return @()
}

# Function to check if a package is installed
function Test-PackageInstalled {
    param ([string]$PackageName)
    return (& scoop list 2>$null) -match "^$PackageName\s"
}

try {
    Write-Host "Running PowerShell version: $($PSVersionTable.PSVersion)"

    # Install Scoop if not present
    if (-not (Test-CommandExists "scoop")) {
        Write-Host "Installing Scoop..."
        Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser -Force
        Invoke-Expression (Invoke-RestMethod -Uri "https://get.scoop.sh")
        if (-not (Test-CommandExists "scoop")) {
            throw "Scoop installation failed."
        }
    } else {
        Write-Host "Scoop is already installed."
    }

    # Install Git if not present
    if (-not (Test-CommandExists "git")) {
        Write-Host "Installing Git via Scoop..."
        & scoop install git
    } else {
        Write-Host "Git is already installed."
    }

    # Process packages from JSON
    $jsonPath = "{{ .chezmoi.sourceDir }}/.chezmoidata/scoop-packages.json"
    if (-not (Test-Path $jsonPath -PathType Leaf)) {
        Write-Warning "JSON file not found at $jsonPath. Skipping package installation."
        return
    }

    Write-Host "Reading packages from $jsonPath..."
    $packages = (Get-Content $jsonPath -Raw | ConvertFrom-Json).packages

    if (-not $packages) {
        Write-Host "No packages found in $jsonPath."
        return
    }

    # Cache current buckets
    $currentBuckets = Get-ScoopBuckets
    Write-Host "Current buckets: $($currentBuckets -join ', ')"

    foreach ($package in $packages) {
        if (-not $package.name -or -not $package.bucket) {
            Write-Warning "Skipping invalid package entry: name or bucket missing."
            continue
        }

        try {
            # Add bucket if needed
            if ($package.bucket -notin $currentBuckets) {
                Write-Host "Adding bucket: $($package.bucket)"
                & scoop bucket add $package.bucket
                $currentBuckets = Get-ScoopBuckets
                Write-Host "Updated buckets: $($currentBuckets -join ', ')"
            }

            # Install package if not already installed
            if (-not (Test-PackageInstalled $package.name)) {
                Write-Host "Installing package: $($package.name) from bucket: $($package.bucket)"
                & scoop install "$($package.bucket)/$($package.name)"
            } else {
                Write-Host "Package $($package.name) is already installed."
            }
        }
        catch {
            Write-Warning "Failed to install $($package.name) from $($package.bucket). Error: $_"
        }
    }

    Write-Host "Scoop setup completed successfully."
}
catch {
    Write-Error "Error during Scoop setup: $_"
    exit 1
}
{{ else }}
# On non-Windows systems, output a message and exit gracefully
Write-Host "This script is designed for Windows only. Skipping execution on {{ .chezmoi.os }}."
{{ end }}